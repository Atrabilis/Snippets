Notebook[{
Cell[BoxData[{
 RowBox[{"Clear", "[", "\"\<Global`*\>\"", "]"}], "\[IndentingNewLine]", 
 RowBox[{"NotebookSave", "[", "]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"Options", "[", "Domains", "]"}], "=", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"DeltaT", "->", "None"}], ",", 
      RowBox[{"TotalT", "->", "None"}], ",", 
      RowBox[{"DeltaF", "->", "None"}], ",", 
      RowBox[{"TotalF", "->", "None"}], ",", 
      RowBox[{"Toffset", "->", "0"}], ",", 
      RowBox[{"Centered", "->", "False"}], ",", 
      RowBox[{"OnlyParameters", "->", "False"}]}], "}"}]}], ";"}], 
  "\n"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"Domains", "[", 
    RowBox[{"n_", ",", "opts___"}], "]"}], ":=", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
      "tos", ",", "Ts", ",", "Ttot", ",", "Fs", ",", "Ftot", ",", "centered", 
       ",", "param", ",", "timedomain", ",", "frequencydomain"}], "}"}], ",", 
     "\[IndentingNewLine]", 
     RowBox[{"(*", 
      RowBox[{"Aignacion", " ", "opciones"}], "*)"}], "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"Ts", "=", 
       RowBox[{
        RowBox[{"DeltaT", "/.", " ", 
         RowBox[{"{", "opts", "}"}]}], "/.", " ", 
        RowBox[{"Options", "[", "Domains", "]"}]}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"Ttot", "=", 
       RowBox[{
        RowBox[{"TotalT", "/.", " ", 
         RowBox[{"{", "opts", "}"}]}], "/.", " ", 
        RowBox[{"Options", "[", "Domains", "]"}]}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"Fs", "=", 
       RowBox[{
        RowBox[{"DeltaF", "/.", " ", 
         RowBox[{"{", "opts", "}"}]}], "/.", " ", 
        RowBox[{"Options", "[", "Domains", "]"}]}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"Ftot", "=", 
       RowBox[{
        RowBox[{"TotalF", "/.", " ", 
         RowBox[{"{", "opts", "}"}]}], "/.", " ", 
        RowBox[{"Options", "[", "Domains", "]"}]}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"tos", "=", 
       RowBox[{
        RowBox[{"Toffset", "/.", " ", 
         RowBox[{"{", "opts", "}"}]}], "/.", " ", 
        RowBox[{"Options", "[", "Domains", "]"}]}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"centered", "=", 
       RowBox[{
        RowBox[{"Centered", "/.", " ", 
         RowBox[{"{", "opts", "}"}]}], "/.", " ", 
        RowBox[{"Options", "[", "Domains", "]"}]}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"param", "=", 
       RowBox[{
        RowBox[{"OnlyParameters", "/.", " ", 
         RowBox[{"{", "opts", "}"}]}], "/.", " ", 
        RowBox[{"Options", "[", "Domains", "]"}]}]}], ";", 
      "\[IndentingNewLine]", "\[IndentingNewLine]", 
      RowBox[{"Switch", "[", 
       RowBox[{
        RowBox[{"First", "[", 
         RowBox[{"Flatten", "[", 
          RowBox[{"Position", "[", 
           RowBox[{
            RowBox[{"N", "[", 
             RowBox[{"{", 
              RowBox[{"Ts", ",", "Ttot", ",", "Fs", ",", "Ftot", ",", "tos"}],
               "}"}], "]"}], ",", 
            RowBox[{"_", "?", "NumberQ"}]}], "]"}], "]"}], "]"}], ",", "1", 
        ",", 
        RowBox[{
         RowBox[{"Ttot", "=", 
          RowBox[{"n", " ", "Ts"}]}], ";", 
         RowBox[{"Fs", "=", 
          RowBox[{"1", "/", "Ttot"}]}], ";", 
         RowBox[{"Ftot", "=", 
          RowBox[{"1", "/", "Ts"}]}]}], ",", "2", ",", 
        RowBox[{
         RowBox[{"Ts", "=", 
          RowBox[{"Ttot", "/", "n"}]}], ";", 
         RowBox[{"Fs", "=", 
          RowBox[{"1", "/", "Ttot"}]}], ";", 
         RowBox[{"Ftot", "=", 
          RowBox[{"1", "/", "Ts"}]}]}], ",", "3", ",", 
        RowBox[{
         RowBox[{"Ts", "=", 
          RowBox[{"1", "/", 
           RowBox[{"(", 
            RowBox[{"n", " ", "Fs"}], ")"}]}]}], ";", 
         RowBox[{"Ttot", "=", 
          RowBox[{"1", "/", "Fs"}]}], ";", 
         RowBox[{"Ftot", "=", 
          RowBox[{"n", " ", "Fs"}]}]}], ",", "4", ",", 
        RowBox[{
         RowBox[{"Ts", "=", 
          RowBox[{"1", "/", "Ftot"}]}], ";", 
         RowBox[{"Ttot", "=", 
          RowBox[{"n", " ", "Ts"}]}], ";", 
         RowBox[{"Fs", "=", 
          RowBox[{"Ftot", "/", "n"}]}]}], ",", "_", ",", 
        RowBox[{
         RowBox[{"Ts", "=", "1"}], ";", 
         RowBox[{"Ttot", "=", "n"}], ";", 
         RowBox[{"Fs", "=", 
          RowBox[{"1", "/", "n"}]}], ";", 
         RowBox[{"Ftot", "=", "1"}]}]}], "]"}], ";", "\[IndentingNewLine]", 
      RowBox[{"If", "[", 
       RowBox[{"param", ",", 
        RowBox[{"Return", "[", 
         RowBox[{"{", 
          RowBox[{"Ts", ",", "Ttot", ",", "Fs", ",", "Ftot"}], "}"}], "]"}], 
        ",", 
        RowBox[{
         RowBox[{"timedomain", "=", 
          RowBox[{"tos", "+", 
           RowBox[{
            RowBox[{"(", 
             RowBox[{
              RowBox[{"Range", "[", "n", "]"}], "-", "1"}], ")"}], "Ts"}]}]}],
          ";", "\[IndentingNewLine]", 
         RowBox[{"frequencydomain", "=", 
          RowBox[{"If", "[", 
           RowBox[{"centered", ",", 
            RowBox[{
             RowBox[{"(", 
              RowBox[{
               RowBox[{"Range", "[", "n", "]"}], "-", 
               RowBox[{"Ceiling", "[", 
                RowBox[{"n", "/", "2"}], "]"}]}], ")"}], "Fs"}], ",", 
            RowBox[{
             RowBox[{"(", 
              RowBox[{
               RowBox[{"Range", "[", "n", "]"}], "-", "1"}], ")"}], "Fs"}]}], 
           "]"}]}], ";", "\[IndentingNewLine]", 
         RowBox[{"Return", "[", 
          RowBox[{"{", 
           RowBox[{"timedomain", ",", "frequencydomain"}], "}"}], "]"}]}]}], 
       "]"}]}]}], "]"}]}], "\n"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"Options", "[", "AddSignalRange", "]"}], "=", 
    RowBox[{"{", 
     RowBox[{"Toffset", "->", "0"}], "}"}]}], ";"}], 
  "\n"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"AddSignalRange", "[", 
    RowBox[{"data_List", ",", "opts___"}], "]"}], ":=", 
   RowBox[{"Transpose", "[", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{
       RowBox[{"Domains", "[", 
        RowBox[{
         RowBox[{"Length", "[", "data", "]"}], ",", "opts"}], "]"}], "[", 
       RowBox[{"[", "1", "]"}], "]"}], ",", "data"}], "}"}], "]"}]}], 
  "\n"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"Options", "[", "AddSpectrumRange", "]"}], "=", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"Centered", "->", "False"}], ",", 
      RowBox[{"HalfSpectrum", "->", "False"}]}], "}"}]}], ";"}], 
  "\n"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"AddSpectrumRange", "[", 
   RowBox[{"data_List", ",", "opts___"}], "]"}], ":=", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"n", ",", "lista", ",", "half", ",", "centered"}], "}"}], ",", 
    RowBox[{
     RowBox[{"half", "=", 
      RowBox[{
       RowBox[{"HalfSpectrum", "/.", " ", 
        RowBox[{"{", "opts", "}"}]}], "/.", " ", 
       RowBox[{"Options", "[", "AddSpectrumRange", "]"}]}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"If", "[", 
      RowBox[{"half", ",", 
       RowBox[{"centered", "=", "False"}], ",", 
       RowBox[{
        RowBox[{"centered", "=", 
         RowBox[{
          RowBox[{"Centered", "/.", " ", 
           RowBox[{"{", "opts", "}"}]}], "/.", " ", 
          RowBox[{"Options", "[", "AddSpectrumRange", "]"}]}]}], ";"}]}], 
      "]"}], ";", "\[IndentingNewLine]", 
     RowBox[{"n", "=", 
      RowBox[{"Length", "[", "data", "]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"lista", "=", 
      RowBox[{"If", "[", 
       RowBox[{"centered", ",", 
        RowBox[{"Transpose", "[", 
         RowBox[{"{", 
          RowBox[{
           RowBox[{
            RowBox[{"Domains", "[", 
             RowBox[{"n", ",", 
              RowBox[{"Centered", "->", "True"}], ",", "opts"}], "]"}], "[", 
            RowBox[{"[", "2", "]"}], "]"}], ",", 
           RowBox[{"RotateRight", "[", 
            RowBox[{"data", ",", 
             RowBox[{
              RowBox[{"Ceiling", "[", 
               RowBox[{"n", "/", "2"}], "]"}], "-", "1"}]}], "]"}]}], "}"}], 
         "]"}], ",", 
        RowBox[{"Transpose", "[", 
         RowBox[{"{", 
          RowBox[{
           RowBox[{
            RowBox[{"Domains", "[", 
             RowBox[{"n", ",", 
              RowBox[{"Centered", "->", "False"}], ",", "opts"}], "]"}], "[", 
            RowBox[{"[", "2", "]"}], "]"}], ",", "data"}], "}"}], "]"}]}], 
       "]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"If", "[", 
      RowBox[{"half", ",", 
       RowBox[{"(*", 
        RowBox[{
        "then", " ", "centered", " ", "is", " ", "forced", " ", "to", " ", 
         "False"}], "*)"}], 
       RowBox[{"Take", "[", 
        RowBox[{"lista", ",", 
         RowBox[{"{", 
          RowBox[{"1", ",", 
           RowBox[{"Ceiling", "[", 
            RowBox[{
             RowBox[{"(", 
              RowBox[{"n", "+", "1"}], ")"}], "/", "2"}], "]"}]}], "}"}]}], 
        "]"}], ",", "lista"}], " ", 
      RowBox[{"(*", 
       RowBox[{"can", " ", "be", " ", "centered", " ", "or", " ", "not"}], 
       "*)"}], "]"}]}]}], "]"}]}], "\[IndentingNewLine]", 
