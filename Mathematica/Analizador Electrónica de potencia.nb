Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{"An\[AAcute]lisis", " ", "Arm\[OAcute]nico"}], "*)"}], 
  "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{"RMSF", " ", "=", " ", 
     SqrtBox[
      RowBox[{
       FractionBox["1", "T"], 
       RowBox[{
        SubsuperscriptBox["\[Integral]", 
         RowBox[{
          RowBox[{"-", "T"}], "/", "2"}], 
         RowBox[{"T", "/", "2"}]], 
        RowBox[{
         SuperscriptBox[
          RowBox[{"F", "[", "\[Theta]", "]"}], "2"], 
         RowBox[{"\[DifferentialD]", "\[Theta]"}]}]}]}]]}], ";"}], 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"ah", "[", "h_", "]"}], ":=", " ", 
    RowBox[{
     FractionBox["1", "\[Pi]"], 
     RowBox[{
      SubsuperscriptBox["\[Integral]", 
       RowBox[{"-", "\[Pi]"}], "\[Pi]"], 
      RowBox[{
       RowBox[{"(", 
        RowBox[{
         RowBox[{"F", "[", "\[Theta]", "]"}], "*", 
         RowBox[{"Cos", "[", 
          RowBox[{"h", "*", "\[Theta]"}], "]"}]}], ")"}], 
       RowBox[{"\[DifferentialD]", "\[Theta]"}]}]}]}]}], 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"bh", "[", "h_", "]"}], ":=", 
    RowBox[{
     FractionBox["1", "\[Pi]"], 
     RowBox[{
      SubsuperscriptBox["\[Integral]", 
       RowBox[{"-", "\[Pi]"}], "\[Pi]"], 
      RowBox[{
       RowBox[{"(", 
        RowBox[{
         RowBox[{"F", "[", "\[Theta]", "]"}], "*", 
         RowBox[{"Sin", "[", 
          RowBox[{"h", "*", "\[Theta]"}], "]"}]}], ")"}], 
       RowBox[{"\[DifferentialD]", "\[Theta]"}]}]}]}]}], 
   "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"serieFourier", "[", 
     RowBox[{"\[Theta]_", ",", "n_"}], "]"}], ":=", " ", 
    RowBox[{
     RowBox[{
      FractionBox["1", "2"], 
      RowBox[{
       SubsuperscriptBox["\[Integral]", 
        RowBox[{"-", "\[Pi]"}], "\[Pi]"], 
       RowBox[{
        RowBox[{"F", "[", "\[Theta]", "]"}], 
        RowBox[{"\[DifferentialD]", "\[Theta]"}]}]}]}], " ", "+", " ", 
     RowBox[{
      UnderoverscriptBox["\[Sum]", 
       RowBox[{"h", "=", "1"}], "n"], 
      RowBox[{"(", 
       RowBox[{
        RowBox[{
         RowBox[{"ah", "[", "h", "]"}], "*", 
         RowBox[{"Cos", "[", 
          RowBox[{"h", "*", "\[Theta]"}], "]"}]}], " ", "+", " ", 
        RowBox[{
         RowBox[{"bh", "[", "h", "]"}], "*", 
         RowBox[{"Sin", "[", 
          RowBox[{"h", "*", "\[Theta]"}], "]"}]}]}], ")"}]}]}]}], 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"RMSh", "[", "h_", "]"}], ":=", 
    FractionBox[
     SqrtBox[
      RowBox[{
       SuperscriptBox[
        RowBox[{"ah", "[", "h", "]"}], "2"], "+", 
       SuperscriptBox[
        RowBox[{"bh", "[", "h", "]"}], "2"]}]], 
     SqrtBox["2"]]}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"FullSimplify", "[", 
     RowBox[{"ah", "[", "h", "]"}], "]"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"FullSimplify", "[", 
     RowBox[{"bh", "[", "h", "]"}], "]"}], ";"}], "\[IndentingNewLine]", 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"iDis", " ", "=", " ", 
     RowBox[{
      RowBox[{"F", "[", 
       RowBox[{
        FractionBox[
         RowBox[{"2", "\[Pi]"}], "Ttemporal"], "*", "t"}], "]"}], " ", "-", 
      " ", 
      RowBox[{"FourierSeries", "[", 
       RowBox[{
        RowBox[{"F", "[", "t", "]"}], ",", "t", ",", "1"}], "]"}]}]}], ";"}], 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"RMSiDis", " ", "=", " ", 
     SqrtBox[
      RowBox[{
       SuperscriptBox["RMSF", "2"], "-", 
       SuperscriptBox[
        RowBox[{"RMSh", "[", "1", "]"}], "2"]}]]}], ";"}], 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"THDi", " ", "=", " ", 
     RowBox[{"100", "*", 
      RowBox[{"(", 
       FractionBox["RMSiDis", 
        RowBox[{"RMSh", "[", "1", "]"}]], ")"}]}]}], ";"}], 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"DPF", " ", "=", " ", "\"\<Por implementar\>\""}], ";"}], 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"PF", " ", "=", " ", 
     RowBox[{
      RowBox[{
       RowBox[{"RMSh", "[", "1", "]"}], "/", "RMSF"}], "*", 
      RowBox[{"Cos", "[", "\[Phi]", "]"}]}]}], ";"}], "\[IndentingNewLine]", 
   "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{"Salida", " ", "datos"}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{"Print", "[", 
    RowBox[{"\"\<Valor RMS de F[\[Theta]]: \>\"", ",", " ", 
