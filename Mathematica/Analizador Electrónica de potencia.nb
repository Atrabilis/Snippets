 RowBox[{"(*", 
  RowBox[{"Gr\[AAcute]fico", " ", "de", " ", "la", " ", "funci\[OAcute]n"}], 
  "*)"}]], "Input",
 CellChangeTimes->{{3.8740860085934086`*^9, 3.8740860196822147`*^9}, {
  3.87408608445088*^9, 3.8740861650176983`*^9}, {3.8740907039513535`*^9, 
