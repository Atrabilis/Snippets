Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{"An\[AAcute]lisis", " ", "Arm\[OAcute]nico"}], "*)"}], 
  "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{"RMSF", " ", "=", " ", 
     SqrtBox[
      RowBox[{
       FractionBox["1", "T"], 
       RowBox[{
        SubsuperscriptBox["\[Integral]", 
         RowBox[{
          RowBox[{"-", "T"}], "/", "2"}], 
         RowBox[{"T", "/", "2"}]], 
        RowBox[{
         SuperscriptBox[
          RowBox[{"F", "[", "\[Theta]", "]"}], "2"], 
         RowBox[{"\[DifferentialD]", "\[Theta]"}]}]}]}]]}], ";"}], 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"ah", "[", "h_", "]"}], ":=", " ", 
    RowBox[{
     FractionBox["1", "\[Pi]"], 
     RowBox[{
      SubsuperscriptBox["\[Integral]", 
       RowBox[{"-", "\[Pi]"}], "\[Pi]"], 
      RowBox[{
       RowBox[{"(", 
        RowBox[{
         RowBox[{"F", "[", "\[Theta]", "]"}], "*", 
         RowBox[{"Cos", "[", 
          RowBox[{"h", "*", "\[Theta]"}], "]"}]}], ")"}], 
       RowBox[{"\[DifferentialD]", "\[Theta]"}]}]}]}]}], 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"bh", "[", "h_", "]"}], ":=", 
    RowBox[{
     FractionBox["1", "\[Pi]"], 
     RowBox[{
      SubsuperscriptBox["\[Integral]", 
       RowBox[{"-", "\[Pi]"}], "\[Pi]"], 
      RowBox[{
       RowBox[{"(", 
        RowBox[{
         RowBox[{"F", "[", "\[Theta]", "]"}], "*", 
         RowBox[{"Sin", "[", 
          RowBox[{"h", "*", "\[Theta]"}], "]"}]}], ")"}], 
       RowBox[{"\[DifferentialD]", "\[Theta]"}]}]}]}]}], 
   "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"serieFourier", "[", 
     RowBox[{"\[Theta]_", ",", "n_"}], "]"}], ":=", " ", 
    RowBox[{
     RowBox[{
      FractionBox["1", "2"], 
      RowBox[{
       SubsuperscriptBox["\[Integral]", 
        RowBox[{"-", "\[Pi]"}], "\[Pi]"], 
       RowBox[{
        RowBox[{"F", "[", "\[Theta]", "]"}], 
        RowBox[{"\[DifferentialD]", "\[Theta]"}]}]}]}], " ", "+", " ", 
     RowBox[{
      UnderoverscriptBox["\[Sum]", 
       RowBox[{"h", "=", "1"}], "n"], 
      RowBox[{"(", 
       RowBox[{
        RowBox[{
         RowBox[{"ah", "[", "h", "]"}], "*", 
         RowBox[{"Cos", "[", 
          RowBox[{"h", "*", "\[Theta]"}], "]"}]}], " ", "+", " ", 
        RowBox[{
         RowBox[{"bh", "[", "h", "]"}], "*", 
         RowBox[{"Sin", "[", 
          RowBox[{"h", "*", "\[Theta]"}], "]"}]}]}], ")"}]}]}]}], 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"RMSh", "[", "h_", "]"}], ":=", 
    FractionBox[
     SqrtBox[
      RowBox[{
       SuperscriptBox[
        RowBox[{"ah", "[", "h", "]"}], "2"], "+", 
       SuperscriptBox[
        RowBox[{"bh", "[", "h", "]"}], "2"]}]], 
     SqrtBox["2"]]}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"FullSimplify", "[", 
     RowBox[{"ah", "[", "h", "]"}], "]"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"FullSimplify", "[", 
     RowBox[{"bh", "[", "h", "]"}], "]"}], ";"}], "\[IndentingNewLine]", 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"iDis", " ", "=", " ", 
     RowBox[{
      RowBox[{"F", "[", "\[Theta]", "]"}], " ", "-", " ", 
      RowBox[{"serieFourier", "[", 
       RowBox[{"\[Theta]", ",", "1"}], "]"}]}]}], ";"}], 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"RMSiDis", " ", "=", " ", 
     SqrtBox[
      RowBox[{
       SuperscriptBox["RMSF", "2"], "-", 
       SuperscriptBox[
        RowBox[{"RMSh", "[", "1", "]"}], "2"]}]]}], ";"}], 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"THDi", " ", "=", " ", 
     RowBox[{"100", "*", 
      RowBox[{"(", 
       FractionBox["RMSiDis", 
        RowBox[{"RMSh", "[", "1", "]"}]], ")"}]}]}], ";"}], 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"DPF", " ", "=", " ", "\"\<Por implementar\>\""}], ";"}], 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"PF", " ", "=", " ", 
     RowBox[{
      RowBox[{
       RowBox[{"RMSh", "[", "1", "]"}], "/", "RMSF"}], "*", 
      RowBox[{"Cos", "[", "\[Phi]", "]"}]}]}], ";"}], "\[IndentingNewLine]", 
   "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{"Salida", " ", "datos"}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{"Print", "[", 
    RowBox[{"\"\<Valor RMS de F[\[Theta]]: \>\"", ",", " ", 
     RowBox[{"RMSF", "//", "N"}]}], "]"}], "\[IndentingNewLine]", 
   RowBox[{"Print", "[", 
    RowBox[{"\"\<Valor RMS del Armonico h: \>\"", ",", " ", 
     RowBox[{"FullSimplify", "[", 
      RowBox[{"RMSh", "[", "h", "]"}], "]"}]}], "]"}], "\[IndentingNewLine]", 
   RowBox[{"Print", "[", 
    RowBox[{"\"\<Valor RMS de la fundamental \>\"", ",", " ", 
     RowBox[{
      RowBox[{"FullSimplify", "[", 
       RowBox[{"RMSh", "[", "1", "]"}], "]"}], "//", "N"}]}], "]"}], 
   "\[IndentingNewLine]", 
   RowBox[{"Print", "[", 
    RowBox[{"\"\<Corriente de distorsi\[OAcute]n: \>\"", ",", " ", 
     RowBox[{"FullSimplify", "[", "iDis", "]"}]}], "]"}], 
   "\[IndentingNewLine]", 
   RowBox[{"Print", "[", 
    RowBox[{
    "\"\<Valor RMS de la corriente de distorsi\[OAcute]n: \>\"", ",", " ", 
     RowBox[{"RMSiDis", "//", "N"}]}], "]"}], "\[IndentingNewLine]", 
   RowBox[{"Print", "[", 
    RowBox[{"\"\<THD: \>\"", ",", " ", 
     RowBox[{"THDi", "//", "N"}]}], "]"}], "\[IndentingNewLine]", 
   RowBox[{"Print", "[", 
    RowBox[{"\"\<Factor de potencia: \>\"", ",", " ", 
     RowBox[{"PF", "//", "N"}]}], "]"}], "\[IndentingNewLine]", 
   RowBox[{"Plot", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"F", "[", "\[Theta]", "]"}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"\[Theta]", ",", "0", ",", 
       RowBox[{"4", "\[Pi]"}]}], "}"}], ",", " ", 
     RowBox[{"PlotLabel", "->", "\"\<F[\[Theta]]\>\""}], ",", 
     RowBox[{"AxesLabel", "->", 
      RowBox[{"{", 
       RowBox[{"\"\<\[Theta]\>\"", ",", "\"\<i(t)\>\""}], "}"}]}], ",", 
     RowBox[{"Filling", "->", "Axis"}]}], "]"}], "\[IndentingNewLine]", 
   RowBox[{"DiscretePlot", "[", 
    RowBox[{
     RowBox[{
      RowBox[{"RMSh", "[", "h", "]"}], "/", 
      RowBox[{"RMSh", "[", "1", "]"}]}], ",", 
     RowBox[{"{", 
      RowBox[{"h", ",", "0", ",", "10"}], "}"}], ",", 
     RowBox[{
     "PlotLabel", "->", "\"\<Espectro Arm\[OAcute]nico de F[\[Theta]]\>\""}], 
     ",", " ", 
     RowBox[{"PlotRange", "->", "Full"}], ",", " ", 
     RowBox[{"AxesLabel", "->", 
      RowBox[{"{", 
       RowBox[{
       "\"\<\[Theta]\>\"", ",", 
        "\"\<\!\(\*SubscriptBox[\(I\), \(h\)]\)/\!\(\*SubscriptBox[\(I\), \(1\
\)]\)\>\""}], "}"}]}]}], "]"}], "\[IndentingNewLine]", 
   RowBox[{"Plot", "[", 
    RowBox[{"iDis", ",", 
     RowBox[{"{", 
      RowBox[{"\[Theta]", ",", " ", "0", ",", "10"}], "}"}], ",", 
     RowBox[{"PlotRange", "->", "All"}], ",", " ", 
     RowBox[{"PlotLabel", "->", "\"\<Corriente de distorsi\[OAcute]n\>\""}]}],
     "]"}], "\[IndentingNewLine]"}]}]], "Input",
