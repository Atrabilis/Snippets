Cell[BoxData[{
 RowBox[{"Clear", "[", "\"\<Global`*\>\"", "]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"vi", " ", "=", " ", "20"}], " ", ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"r", " ", "=", " ", "2000"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"c", " ", "=", " ", 
   RowBox[{"2000", "*", 
    SuperscriptBox["10", 
     RowBox[{"-", "12"}]]}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"zc", " ", "=", " ", 
   FractionBox[
    RowBox[{"-", "\[ImaginaryJ]"}], 
    RowBox[{"2", "*", "Pi", "*", "f", "*", "c"}]]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"vo", "[", "f_", "]"}], " ", "=", " ", 
   RowBox[{"vi", " ", "*", 
    RowBox[{"(", 
     FractionBox["zc", 
      RowBox[{"r", "+", "zc"}]], ")"}]}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"voabs", "[", "f_", "]"}], "=", 
   RowBox[{"ComplexExpand", "[", 
    RowBox[{"Abs", "[", 
     RowBox[{"FullSimplify", "[", 
      RowBox[{"vo", "[", "f", "]"}], "]"}], "]"}], "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"fo", " ", "=", " ", 
   RowBox[{
    RowBox[{"f", " ", "/.", " ", 
     RowBox[{
      RowBox[{"Solve", "[", 
       RowBox[{
        RowBox[{
         RowBox[{"voabs", "[", "f", "]"}], "\[Equal]", " ", 
         RowBox[{
          FractionBox["1", 
           SqrtBox["2"]], 
          RowBox[{"voabs", "[", "0", "]"}]}]}], ",", "f"}], "]"}], "[", 
      RowBox[{"[", "2", "]"}], "]"}]}], "//", "N"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{"a", " ", "=", " ", 
  RowBox[{"LogLinearPlot", "[", 
   RowBox[{
    RowBox[{"{", 
