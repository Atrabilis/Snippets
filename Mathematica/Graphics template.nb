          RowBox[{"{", 
           RowBox[{
            RowBox[{"Log", "[", "1", "]"}], ",", 
            RowBox[{"voabs", "[", "fo", "]"}]}], "}"}], ",", 
          RowBox[{"{", 
           RowBox[{
            RowBox[{"Log", "[", "fo", "]"}], ",", 
            RowBox[{"voabs", "[", "fo", "]"}]}], "}"}], ",", 
          RowBox[{"{", 
