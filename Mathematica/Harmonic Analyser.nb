Cell[BoxData[
 InterpretationBox[
  RowBox[{"\<\"Corriente de distorsi\[OAcute]n: \"\>", "\[InvisibleSpace]", 
   RowBox[{
    RowBox[{"-", 
     FractionBox[
      RowBox[{"2", " ", 
       RowBox[{"(", 
        RowBox[{
         RowBox[{"-", "1"}], "+", 
         SqrtBox["3"]}], ")"}], " ", 
       RowBox[{"Cos", "[", "t", "]"}]}], "\[Pi]"]}], "-", 
    RowBox[{"UnitStep", "[", 
     RowBox[{
      RowBox[{"-", 
       FractionBox[
        RowBox[{"11", " ", "\[Pi]"}], "6"]}], "+", 
      RowBox[{"Mod", "[", 
       RowBox[{
        RowBox[{"50", " ", "t"}], ",", 
        RowBox[{"2", " ", "\[Pi]"}], ",", "0"}], "]"}]}], "]"}], "+", 
    RowBox[{"UnitStep", "[", 
     RowBox[{
      RowBox[{"-", 
       FractionBox[
        RowBox[{"5", " ", "\[Pi]"}], "3"]}], "+", 
      RowBox[{"Mod", "[", 
       RowBox[{
        RowBox[{"50", " ", "t"}], ",", 
        RowBox[{"2", " ", "\[Pi]"}], ",", "0"}], "]"}]}], "]"}], "+", 
    RowBox[{"UnitStep", "[", 
     RowBox[{
      RowBox[{"-", 
       FractionBox[
        RowBox[{"4", " ", "\[Pi]"}], "3"]}], "+", 
      RowBox[{"Mod", "[", 
       RowBox[{
        RowBox[{"50", " ", "t"}], ",", 
        RowBox[{"2", " ", "\[Pi]"}], ",", "0"}], "]"}]}], "]"}], "-", 
    RowBox[{"UnitStep", "[", 
     RowBox[{
      RowBox[{"-", 
       FractionBox[
        RowBox[{"7", " ", "\[Pi]"}], "6"]}], "+", 
      RowBox[{"Mod", "[", 
       RowBox[{
        RowBox[{"50", " ", "t"}], ",", 
        RowBox[{"2", " ", "\[Pi]"}], ",", "0"}], "]"}]}], "]"}], "+", 
    RowBox[{"UnitStep", "[", 
     RowBox[{
      RowBox[{"-", 
       FractionBox[
        RowBox[{"5", " ", "\[Pi]"}], "6"]}], "+", 
      RowBox[{"Mod", "[", 
       RowBox[{
        RowBox[{"50", " ", "t"}], ",", 
        RowBox[{"2", " ", "\[Pi]"}], ",", "0"}], "]"}]}], "]"}], "-", 
    RowBox[{"UnitStep", "[", 
     RowBox[{
      RowBox[{"-", 
       FractionBox[
        RowBox[{"2", " ", "\[Pi]"}], "3"]}], "+", 
      RowBox[{"Mod", "[", 
       RowBox[{
        RowBox[{"50", " ", "t"}], ",", 
        RowBox[{"2", " ", "\[Pi]"}], ",", "0"}], "]"}]}], "]"}], "-", 
    RowBox[{"UnitStep", "[", 
     RowBox[{
      RowBox[{"-", 
       FractionBox["\[Pi]", "3"]}], "+", 
      RowBox[{"Mod", "[", 
       RowBox[{
        RowBox[{"50", " ", "t"}], ",", 
        RowBox[{"2", " ", "\[Pi]"}], ",", "0"}], "]"}]}], "]"}], "+", 
    RowBox[{"UnitStep", "[", 
     RowBox[{
      RowBox[{"-", 
       FractionBox["\[Pi]", "6"]}], "+", 
      RowBox[{"Mod", "[", 
       RowBox[{
        RowBox[{"50", " ", "t"}], ",", 
        RowBox[{"2", " ", "\[Pi]"}], ",", "0"}], "]"}]}], "]"}]}]}],
  SequenceForm[
  "Corriente de distorsi\[OAcute]n: ", (-2) (-1 + 3^Rational[1, 2]) Pi^(-1) 
    Cos[$CellContext`t] - UnitStep[
   Rational[-11, 6] Pi + Mod[50 $CellContext`t, 2 Pi, 0]] + 
   UnitStep[Rational[-5, 3] Pi + Mod[50 $CellContext`t, 2 Pi, 0]] + 
   UnitStep[Rational[-4, 3] Pi + Mod[50 $CellContext`t, 2 Pi, 0]] - UnitStep[
   Rational[-7, 6] Pi + Mod[50 $CellContext`t, 2 Pi, 0]] + 
   UnitStep[Rational[-5, 6] Pi + Mod[50 $CellContext`t, 2 Pi, 0]] - UnitStep[
   Rational[-2, 3] Pi + Mod[50 $CellContext`t, 2 Pi, 0]] - UnitStep[
   Rational[-1, 3] Pi + Mod[50 $CellContext`t, 2 Pi, 0]] + 
   UnitStep[Rational[-1, 6] Pi + Mod[50 $CellContext`t, 2 Pi, 0]]],
  Editable->False]], "Print",
