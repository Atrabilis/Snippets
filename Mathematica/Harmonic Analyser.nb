Cell[BoxData[
 InterpretationBox[
  RowBox[{"\<\"Valor RMS del Armonico h: \"\>", "\[InvisibleSpace]", 
   FractionBox[
    RowBox[{"8", " ", 
     SqrtBox["2"], " ", 
     SqrtBox[
      FractionBox[
       RowBox[{
        SuperscriptBox[
         RowBox[{"(", 
          RowBox[{"1", "+", 
           RowBox[{"2", " ", 
            RowBox[{"Cos", "[", 
             FractionBox[
              RowBox[{"h", " ", "\[Pi]"}], "6"], "]"}]}]}], ")"}], "4"], " ", 
        SuperscriptBox[
         RowBox[{"Cos", "[", 
          FractionBox[
           RowBox[{"h", " ", "\[Pi]"}], "4"], "]"}], "2"], " ", 
        SuperscriptBox[
         RowBox[{"Sin", "[", 
          FractionBox[
           RowBox[{"h", " ", "\[Pi]"}], "12"], "]"}], "6"]}], 
       SuperscriptBox["h", "2"]]]}], "\[Pi]"]}],
  SequenceForm[
  "Valor RMS del Armonico h: ", 8 2^Rational[1, 2] 
   Pi^(-1) ($CellContext`h^(-2) (1 + 
       2 Cos[Rational[1, 6] $CellContext`h Pi])^4 
     Cos[Rational[1, 4] $CellContext`h Pi]^2 
     Sin[Rational[1, 12] $CellContext`h Pi]^6)^Rational[1, 2]],
  Editable->False]], "Print",
 CellChangeTimes->{3.8758878716471524`*^9, 3.8758880176895146`*^9, 
  3.8758881693875184`*^9},
 CellLabel->
  "Durante la evaluaci\[OAcute]n de \
In[115]:=",ExpressionUUID->"a0542e75-8452-4e07-9b88-9c572e85956f"],

