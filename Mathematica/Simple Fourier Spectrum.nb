Cell[CellGroupData[{
Cell[BoxData[{
 RowBox[{
  RowBox[{"Clear", "[", "\"\<Global`*\>\"", "]"}], "\[IndentingNewLine]", 
  RowBox[{"(*", 
   RowBox[{"Datos", " ", "de", " ", "muestreo"}], 
   "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"fs", "=", 
    RowBox[{"3", "*", 
     SuperscriptBox["10", "6"]}]}], ";", " ", 
   RowBox[{"(*", 
    RowBox[{"<", 
     RowBox[{
      RowBox[{"-", " ", "Frecuencia"}], " ", "de", " ", "muestreo"}]}], 
    "*)"}], "\[IndentingNewLine]", 
   RowBox[{"ps", " ", "=", " ", 
    RowBox[{"1", "/", "fs"}]}], ";", " ", 
   RowBox[{"(*", 
    RowBox[{"<", 
     RowBox[{
      RowBox[{"-", " ", "Periodo"}], " ", "de", " ", "muestreo"}]}], "*)"}], 
   "\[IndentingNewLine]", 
   RowBox[{"L", "=", "10000"}], ";", " ", 
   RowBox[{"(*", 
    RowBox[{"<", 
     RowBox[{
      RowBox[{"-", " ", "Numero"}], " ", "de", " ", "muestras"}]}], "*)"}], 
   "\n", "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{"vector", " ", "tiempo"}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{"t", "=", 
    RowBox[{"ps", "*", 
     RowBox[{"Range", "[", 
      RowBox[{"0", ",", 
       RowBox[{"L", "-", "1"}]}], "]"}]}]}], ";"}], "\[IndentingNewLine]", 
  RowBox[{"(*", 
   RowBox[{"vector", " ", "frecuencia"}], "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"f", "=", 
    RowBox[{
     RowBox[{"(", 
      RowBox[{"fs", "/", "2"}], ")"}], "*", 
     RowBox[{"Range", "[", 
      RowBox[{
       RowBox[{
        RowBox[{"-", "1"}], "+", 
        RowBox[{"2", "/", "L"}]}], ",", "1", ",", 
       RowBox[{"2", "/", "L"}]}], "]"}]}]}], ";"}], "\[IndentingNewLine]", 
  RowBox[{"(*", 
   RowBox[{"Funci\[OAcute]n", " ", "a", " ", "Muestrear"}], 
   "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"mensaje", "=", " ", 
   RowBox[{
    RowBox[{"2", "*", 
     RowBox[{"Cos", "[", 
      RowBox[{"2", "*", "2000", "\[Pi]", "*", "t"}], "]"}]}], " ", "+", " ", 
    RowBox[{"Cos", "[", 
     RowBox[{"2", "*", "1000", "\[Pi]", "*", "t"}], "]"}]}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"portadora", " ", "=", " ", 
   RowBox[{"Cos", "[", 
    RowBox[{"2", "*", "\[Pi]", "*", 
     SuperscriptBox["10", "6"], "*", "t"}], "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"modulada", " ", "=", " ", 
    RowBox[{"mensaje", "*", "portadora"}]}], ";"}], "\[IndentingNewLine]", 
  RowBox[{"(*", 
   RowBox[{"Transformada", " ", "de", " ", 
    RowBox[{"F", ".", " ", "de"}], " ", "la", " ", "funcion", " ", 
    "muestreada"}], "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"fouriermensaje", " ", "=", " ", 
    RowBox[{
     RowBox[{"Fourier", "[", 
      RowBox[{"modulada", ",", 
       RowBox[{"FourierParameters", "\[Rule]", 
        RowBox[{"{", 
         RowBox[{"1", ",", " ", 
          RowBox[{"-", "1"}]}], "}"}]}]}], "]"}], "/", "L"}]}], ";"}], 
  "\[IndentingNewLine]", 
  RowBox[{"(*", 
   RowBox[{"Espectro", " ", "de", " ", "frecuencias"}], 
   "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"ListLinePlot", "[", 
   RowBox[{
    RowBox[{"Transpose", "[", 
     RowBox[{"{", 
      RowBox[{"f", ",", 
       RowBox[{"RotateRight", "[", 
        RowBox[{
         RowBox[{"Abs", "[", "fouriermensaje", "]"}], ",", 
         RowBox[{
          RowBox[{"Ceiling", "[", 
           RowBox[{"L", "/", "2"}], "]"}], "-", "1"}]}], "]"}]}], "}"}], 
     "]"}], ",", "\[IndentingNewLine]", 
    RowBox[{"PlotRange", "\[Rule]", "All"}], ",", "\[IndentingNewLine]", 
    RowBox[{"AxesLabel", "\[Rule]", 
     RowBox[{"{", 
      RowBox[{"\"\<f[Hz]\>\"", ",", "\"\<|F(\[Omega])|\>\""}], "}"}]}], ",", 
    "\[IndentingNewLine]", 
    RowBox[{"PlotLabel", "\[Rule]", "\"\<Espectro de frecuencias\>\""}]}], 
   "]"}], "\[IndentingNewLine]", 
  RowBox[{"(*", "desfase", "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"desfase", " ", "=", " ", 
   RowBox[{"Table", "[", 
    RowBox[{
     RowBox[{"ArcTan", "[", 
      FractionBox[
       RowBox[{"Im", "[", 
        RowBox[{"fouriermensaje", " ", "[", 
         RowBox[{"[", "i", "]"}], "]"}], "]"}], 
       RowBox[{"Re", "[", 
        RowBox[{"fouriermensaje", " ", "[", 
         RowBox[{"[", "i", "]"}], "]"}], "]"}]], "]"}], ",", 
     RowBox[{"{", 
      RowBox[{"i", ",", "1", ",", "L"}], "}"}]}], "]"}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"ListLinePlot", "[", 
   RowBox[{"Transpose", "[", 
    RowBox[{"{", 
     RowBox[{"f", ",", "desfase"}], "}"}], "]"}], "]"}], 
